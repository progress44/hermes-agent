FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie@sha256:b3c543b6c4f23a5f2df22866bd7857e5d304b67a564f4feab6ac22044dde719b AS uv_source
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright
ENV HERMES_HOME=/opt/hermes-home
ENV HOME=/home/node
ENV HERMES_WEB_DIST=/opt/hermes/hermes_cli/web_dist
ENV HERMES_TUI_DIR=/opt/hermes/ui-tui
ENV HERMES_PYTHON=/opt/hermes/.venv/bin/python
ENV HERMES_ENABLE_GATEWAY=0
ENV HERMES_ENABLE_API_SERVER=0
ENV API_SERVER_ENABLED=0
ENV PATH="/opt/hermes/.venv/bin:/home/node/.local/bin:/usr/local/bin:/usr/bin:/bin"

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        docker-cli \
        ffmpeg \
        gcc \
        git \
        libffi-dev \
        nodejs \
        npm \
        openssh-client \
        procps \
        python3 \
        python3-dev \
        ripgrep \
        tini && \
    rm -rf /var/lib/apt/lists/*

RUN /usr/sbin/addgroup --gid 1000 hermes && \
    /usr/sbin/adduser --uid 1000 --gid 1000 --home /home/node --disabled-password --gecos "" hermes

COPY --chmod=0755 --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/

WORKDIR /opt/hermes

# Cache the browser-tooling install separately from application source changes.
COPY package.json package-lock.json ./
COPY web/package.json web/package-lock.json web/

RUN npm install --prefer-offline --no-audit && \
    npx playwright install --with-deps chromium --only-shell && \
    (cd web && npm install --prefer-offline --no-audit) && \
    npm cache clean --force

COPY . .

RUN chmod 0755 docker/olares-entrypoint.sh && \
    cd ui-tui && npm install --prefer-offline --no-audit && npm run build && \
    cd /opt/hermes/web && npm run build && \
    cd /opt/hermes && uv venv && uv pip install --no-cache-dir -e ".[all]" && \
    mkdir -p /home/node/.local/bin /home/node/.npm-global/bin /opt/hermes-home && \
    printf '%s\n' 'export PATH="/opt/hermes/.venv/bin:/home/node/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH"' > /etc/profile.d/hermes-olares-path.sh && \
    chmod 0644 /etc/profile.d/hermes-olares-path.sh && \
    chown -R 1000:1000 /home/node /opt/hermes-home && \
    chmod -R a+rX /opt/hermes

USER hermes

ENTRYPOINT ["/usr/bin/tini", "-g", "--", "/opt/hermes/docker/olares-entrypoint.sh"]
